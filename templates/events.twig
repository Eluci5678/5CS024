{% include 'header.twig' %}
{% include 'top-bar.twig'%}

<body>
    <div class="main">
        <a href="index.php" class="btn btn-primary" style="margin-bottom: 5px;">Home</a>

        {% for row in data %}
            <div class="info-panel">
                <a href="event-info.php?id={{ row.event_id }}" class="title"><h1>{{ row.title }}</h1></a>
                <p>{{ row.events_description }}</p>
                <p>Type: {{row.event_type}}</p>
                <p>Starts: {{row.start_time}}</p>
                <p>Ends: {{row.end_time}}</p>
                {% if row.joined %}
                    <a class="btn btn-danger" href="php/student/register-item.php?type=event&id={{ row.event_id }}&action=leave" role="button">Leave</a>
                {% else %}
                    <a class="btn btn-primary" href="php/student/register-item.php?type=event&id={{ row.event_id }}&action=join" role="button">Join</a>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</body>

{% include 'footer.twig' %}